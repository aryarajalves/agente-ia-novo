# Configurações do Banco de Dados
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_agent_db
POSTGRES_PORT_EXTERNAL=5433

# Chaves de API de IA [OBRIGATÓRIO]
OPENAI_API_KEY=sua_chave_aqui
GEMINI_API_KEY=sua_chave_aqui
ANTHROPIC_API_KEY=sua_chave_aqui
ASSEMBLYAI_API_KEY=sua_chave_aqui
# Taxa de conversão USD para BRL para exibição de custos
USD_TO_BRL_RATE=6.0

# Configurações de Segurança [OBRIGATÓRIO]
JWT_SECRET_KEY=sua_chave_secreta_jwt
AGENT_API_KEY=sua_chave_mestra_api
VITE_AGENT_API_KEY=mesma_chave_mestra_api

# URLs de Comunicação [OBRIGATÓRIO]
# URL pública do backend para redirecionamentos e webhooks
BACKEND_URL=https://sua-api.dominio.com
# URL da API usada pelo frontend (Vite)
VITE_API_URL=https://sua-api.dominio.com
# Origens permitidas para CORS (separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:5300,https://seu-painel.dominio.com

# Acesso Administrativo Inicial
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=senha_segura

# Integração Google Calendar
GOOGLE_CLIENT_ID=seu_client_id
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REDIRECT_URI=https://sua-api.dominio.com/integrations/google/callback

# Storage S3/Backblaze
S3_ENDPOINT_URL=https://s3.regiao.backblazeb2.com
S3_ACCESS_KEY=sua_access_key
S3_SECRET_KEY=sua_secret_key
S3_BUCKET_NAME=nome-do-bucket
S3_REGION=sua-regiao

# Redis/Celery
REDIS_URL=redis://redis:6379/0

# Cloudflare Tunnel (Opcional para Local)
CLOUDFLARE_TUNNEL_URL=https://sua-api.dominio.com
CLOUDFLARE_TUNNEL_TOKEN=seu_token_aqui

# Chatwoot Integration
CHATWOOT_URL=https://seu-chatwoot.com
CHATWOOT_API_TOKEN=seu_token_chatwoot
